# Admin passcode for score entry at the fields (everyone shares one).
ADMIN_PASSCODE=change-me

# Secret used to sign the admin session cookie. Use a long random string.
SESSION_SECRET=replace-with-a-long-random-string

# Leave UNSET for local dev (uses an in-memory store).
# For the live tournament, set this to your Azure SQL connection string and
# create the GameResult table (see README) -- the app then persists to Azure SQL.
# AZURE_SQL_CONNECTION=Server=tcp:yourserver.database.windows.net,1433;Database=lpfc3v3;User Id=...;Password=...;Encrypt=true
